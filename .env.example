# Copy this to .env and fill in your values.
# Never commit .env to version control.

# Sleeper API (no auth needed — public)
SLEEPER_BASE_URL=https://api.sleeper.app/v1

# Reddit PRAW credentials
# Create an app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=ff-guess-player/0.1 (by /u/yourusername)

# Google Gemini (get key at aistudio.google.com)
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash

# Telegram Bot
# Create a bot via @BotFather and get the chat ID from @userinfobot
TELEGRAM_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=your_chat_id

# YouTube OAuth
YOUTUBE_CLIENT_SECRETS_FILE=client_secrets.json

# Output directories (defaults shown)
OUTPUT_DIR=output
FRAMES_DIR=output/frames
AUDIO_DIR=output/audio

# Season settings
SEASON_YEAR=2024
WEEK=1
